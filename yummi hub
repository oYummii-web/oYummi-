-- Utilitário Teleportar
local function tpTo(part)
    if part then
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        hrp.CFrame = part.CFrame + Vector3.new(0,0,3)
    end
end

-- Utilitário falar com o NPC Bleach Raid (ProximityPrompt)
local function talkNpc()
    local npc = workspace:FindFirstChild("Bleach Raid")
    if npc and npc:FindFirstChild("HumanoidRootPart") then
        tpTo(npc.HumanoidRootPart)
        wait(0.5)
        for _,v in ipairs(npc:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                if fireproximityprompt then fireproximityprompt(v)
                else
                    v:InputHoldBegin()
                    wait(0.20)
                    v:InputHoldEnd()
                end
                break
            end
        end
    end
end

-- Utilitário selecionar opção de diálogo
local function selectDialogue()
    -- Tenta achar botão na tela com texto alvo
    local function clickDialogue()
        for _,v in ipairs(game.CoreGui:GetDescendants()) do
            if v:IsA("TextButton") and v.Text == "I want to fight the villains!" then
                v:Activate()
                return true
            end
        end
        return false
    end
    local timer = 3
    while timer > 0 do
        if clickDialogue() then break end
        wait(0.25)
        timer -= 0.25
    end
end

-- Helper: Matar inimigo mais próximo na raid
local function killNearestLoop()
    while autoRaid do
        -- ENEMY NPCs: personalize filtro!
        local playerChar = player.Character
        local nearest, dist
        for _,npc in ipairs(workspace:GetDescendants()) do
            if npc:IsA("Model") and npc ~= playerChar and npc:FindFirstChild("Humanoid") and npc:FindFirstChild("HumanoidRootPart") then
                if npc.Humanoid.Health > 0 and (not dist or (npc.HumanoidRootPart.Position - playerChar.HumanoidRootPart.Position).Magnitude < dist) then
                    nearest = npc
                    dist = (npc.HumanoidRootPart.Position - playerChar.HumanoidRootPart.Position).Magnitude
                end
            end
        end
        if nearest then
            repeat
                -- Simulação: Health=0 (substitua por remote/call se necessário)
                nearest.Humanoid.Health = 0
                wait(0.25)
            until not autoRaid or nearest.Humanoid.Health <= 0 or not nearest.Parent
        end
        wait(0.25)
    end
end

